# Mimir FOB — Environment Variables
# Copy this to .env and edit before running docker compose up.

# ── Web service ───────────────────────────────────────────────────────────────
MIMIR_USER=admin                    # Django superuser username (created on first start)
MIMIR_EMAIL=admin@localhost         # Django superuser email
MIMIR_PASSWORD=changeme             # ⚠️  Change this!  Used by the MCP facade to get a token.
DJANGO_DEBUG=False
WEB_PORT=8000                       # Host port for the web UI

# ── MCP facade ────────────────────────────────────────────────────────────────
MCP_PORT=8001                       # Host port for the MCP SSE endpoint
# MIMIR_TOKEN=                      # Optional: provide a pre-existing DRF token.
#                                   # If blank, the facade auto-fetches one at startup.

# ── Galdr AI Engine ───────────────────────────────────────────────────────────
# Galdr uses Anthropic Claude to assess PIP Changes. See docs/architecture/SAO.md § Galdr AI.
# Default model: claude-sonnet-4-5. Override with any Anthropic model slug.
ANTHROPIC_API_KEY=sk-ant-...          # required for Galdr to function
GALDR_MODEL=claude-sonnet-4-5         # default model; Sonnet 4.5 recommended

# ── AWS ECR (for CI/CD) ───────────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
# ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
