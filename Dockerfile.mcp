FROM python:3.14-slim

LABEL maintainer="Denis Petelin <denis.petelin@example.com>"
LABEL description="Mimir MCP Facade — HTTP-client MCP server (no Django, no ORM)"

# Minimal environment
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Install only facade dependencies (fastmcp + httpx)
COPY requirements-facade.txt .
RUN pip install --no-cache-dir -r requirements-facade.txt

# Copy only the facade package
COPY mcp_integration/__init__.py ./mcp_integration/__init__.py
COPY mcp_integration/facade/ ./mcp_integration/facade/

# Default environment — token must be provided at runtime
ENV MIMIR_SERVER_URL=http://web:8000
ENV MIMIR_TOKEN=""
ENV MCP_HOST=0.0.0.0
ENV MCP_PORT=8001

# Expose SSE port
EXPOSE 8001

# Health check — verify the facade can start (it will fail fast if not configured)
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "from mcp_integration.facade.client import get_client; print('ok')" 2>/dev/null || exit 1

# Default: SSE transport for container deployments
# Override with: docker run ... --transport=stdio (for Windsurf)
ENTRYPOINT ["python", "-m", "mcp_integration.facade.server"]
CMD ["--transport=sse"]
