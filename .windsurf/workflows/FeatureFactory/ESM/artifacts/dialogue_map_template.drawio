<mxfile host="65bd71144e">
    <diagram name="{ProjectName} Screen Flow" id="screen-flow">
        <mxGraphModel dx="1332" dy="644" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                
                <!-- Title -->
                <mxCell id="title" value="{ProjectName} - {FlowName}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4a90e2;strokeColor=#2e5c8a;fontSize=24;fontStyle=1;fontColor=#ffffff;align=center;" vertex="1" parent="1">
                    <mxGeometry x="80" y="40" width="1240" height="80" as="geometry"/>
                </mxCell>
                
                <!-- Screen 1: LIST+FIND -->
                <mxCell id="screen-list" value="{ScreenID}-LIST+FIND&#10;&#10;{EntityName} List&#10;• Search & Filter&#10;• Table with actions&#10;• Create button" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#0066cc;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
                    <mxGeometry x="120" y="200" width="200" height="120" as="geometry"/>
                </mxCell>
                
                <!-- Screen 2: CREATE -->
                <mxCell id="screen-create" value="{ScreenID}-CREATE_{ENTITY}&#10;&#10;Create {EntityName}&#10;• Form fields&#10;• Validation&#10;• Save/Cancel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
                    <mxGeometry x="400" y="200" width="200" height="120" as="geometry"/>
                </mxCell>
                
                <!-- Screen 3: VIEW -->
                <mxCell id="screen-view" value="{ScreenID}-VIEW_{ENTITY}&#10;&#10;View {EntityName}&#10;• Details display&#10;• Edit/Delete actions&#10;• Related items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ffc107;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
                    <mxGeometry x="680" y="200" width="200" height="120" as="geometry"/>
                </mxCell>
                
                <!-- Screen 4: EDIT -->
                <mxCell id="screen-edit" value="{ScreenID}-EDIT_{ENTITY}&#10;&#10;Edit {EntityName}&#10;• Pre-filled form&#10;• Validation&#10;• Save/Cancel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e7f3ff;strokeColor=#0066cc;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
                    <mxGeometry x="960" y="200" width="200" height="120" as="geometry"/>
                </mxCell>
                
                <!-- Screen 5: DELETE -->
                <mxCell id="screen-delete" value="{ScreenID}-DELETE_{ENTITY}&#10;&#10;Delete Confirmation&#10;• Warning message&#10;• Confirm/Cancel&#10;• Impact notice" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#dc3545;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
                    <mxGeometry x="680" y="400" width="200" height="120" as="geometry"/>
                </mxCell>
                
                <!-- Arrows: LIST to CREATE -->
                <mxCell id="arrow-list-create" value="[Create]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#28a745;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="screen-list" target="screen-create">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                
                <!-- Arrows: CREATE to VIEW -->
                <mxCell id="arrow-create-view" value="[Save]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#28a745;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="screen-create" target="screen-view">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                
                <!-- Arrows: LIST to VIEW -->
                <mxCell id="arrow-list-view" value="[View]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#0066cc;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" edge="1" parent="1" source="screen-list" target="screen-view">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                
                <!-- Arrows: VIEW to EDIT -->
                <mxCell id="arrow-view-edit" value="[Edit]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#0066cc;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="screen-view" target="screen-edit">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                
                <!-- Arrows: EDIT to VIEW -->
                <mxCell id="arrow-edit-view" value="[Save]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#28a745;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="screen-edit" target="screen-view">
