                </mxCell>
                <mxCell id="legend-create" value="Green: Create/Success" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="120" y="680" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="legend-delete" value="Red: Delete/Danger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#dc3545;fontSize=11;" vertex="1" parent="1">
                    <mxGeometry x="120" y="720" width="200" height="30" as="geometry"/>
                </mxCell>
                
                <!-- Instructions -->
                <mxCell id="instructions" value="📝 Instructions:&#10;1. Replace {ProjectName}, {EntityName}, {ScreenID} with actual values&#10;2. Add/remove screens as needed for your flow&#10;3. Update arrows to match your navigation&#10;4. Use color coding: Blue (view), Green (create/success), Red (delete/danger)&#10;5. Include action labels on arrows: [Create], [Edit], [Save], [Delete], [Cancel]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ffc107;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10;" vertex="1" parent="1">
                    <mxGeometry x="400" y="600" width="480" height="150" as="geometry"/>
