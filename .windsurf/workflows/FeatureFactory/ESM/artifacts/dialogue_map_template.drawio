                <!-- Arrows: VIEW to DELETE -->
                <mxCell id="arrow-view-delete" value="[Delete]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#dc3545;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="screen-view" target="screen-delete">
                    <mxGeometry relative="1" as="geometry"/>
