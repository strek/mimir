                <!-- Legend -->
                <mxCell id="legend-title" value="Legend" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e9ecef;strokeColor=#6c757d;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
                    <mxGeometry x="120" y="600" width="200" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="legend-list" value="Blue: List/View screens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#0066cc;fontSize=11;" vertex="1" parent="1">
