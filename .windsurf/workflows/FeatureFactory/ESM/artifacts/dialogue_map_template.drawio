                <!-- Arrows: DELETE to LIST -->
                <mxCell id="arrow-delete-list" value="[Confirm]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#dc3545;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="screen-delete" target="screen-list">
                    <mxGeometry relative="1" as="geometry"/>
